{
  "info": {
    "name": "bookstore-api",
    "_postman_id": "a58a69de-a5a1-4f0e-8bde-3d6fcb5584c7",
    "description": "Colección base para probar bookstore-api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Julian Mejia\",\n  \"email\": \"julian@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@bookstore.com\",\n  \"password\": \"Admin1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Get Books",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/books?page=0&size=10"
          }
        },
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Spring in Action\",\n  \"description\": \"Libro tecnico\",\n  \"price\": 89.9,\n  \"stock\": 8,\n  \"isbn\": \"9781617297571\",\n  \"authorId\": 1,\n  \"categoryIds\": [1, 2]\n}"
            },
            "url": "{{baseUrl}}/books"
          }
        }
      ]
    },
    {
      "name": "Authors",
      "item": [
        {
          "name": "Get Authors",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/authors"
          }
        },
        {
          "name": "Create Author",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Martin Fowler\",\n  \"biography\": \"Autor y referente de arquitectura.\",\n  \"contactInfo\": \"martin@example.com\"\n}"
            },
            "url": "{{baseUrl}}/authors"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Arquitectura\",\n  \"description\": \"Libros de arquitectura de software\"\n}"
            },
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"bookId\": 1,\n      \"quantity\": 2\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/orders/my"
          }
        },
        {
          "name": "Confirm Order",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/orders/1/confirm"
          }
        }
      ]
    }
  ]
}
